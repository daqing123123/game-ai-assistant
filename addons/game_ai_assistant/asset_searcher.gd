extends Node

## 素材搜索器 - 搜索 Kenney、freesound 等免费可商用素材

var http_client: HTTPRequest
var current_results: Array = []
var search_callback: Callable

const ASSET_SOURCES = {
	"kenney": {
		"name": "Kenney.nl",
		"url": "https://kenney.nl/assets",
		"license": "CC0",
		"free": true,
		"commercial": true,
		"description": "最全的免费游戏素材，包含精灵、UI、音效、3D模型"
	},
	"freesound": {
		"name": "Freesound",
		"url": "https://freesound.org",
		"license": "CC0/CC-BY",
		"free": true,
		"commercial": true,
		"description": "免费音效库，包含环境音、动作音效、音乐"
	},
	"opengameart": {
		"name": "OpenGameArt",
		"url": "https://opengameart.org",
		"license": "Various",
		"free": true,
		"commercial": true,
		"description": "开源游戏艺术社区，2D/3D/音频素材"
	},
	"game-icons": {
		"name": "Game Icons",
		"url": "https://game-icons.net",
		"license": "CC0",
		"free": true,
		"commercial": true,
		"description": "免费游戏图标，SVG矢量格式"
	}
}

func _ready() -> void:
	http_client = HTTPRequest.new()
	add_child(http_client)
	http_client.request_completed.connect(_on_search_completed)

## 获取可用素材源
func get_sources() -> Array:
	var sources: Array = []
	for key in ASSET_SOURCES.keys():
		sources.append(ASSET_SOURCES[key])
	return sources

## 搜索素材
func search(query: String, source: String = "all", callback: Callable = Callable()) -> void:
	search_callback = callback
	
	# 根据关键词分类
	var category = _guess_category(query)
	
	match category:
		"audio", "sound", "音效", "爆炸", "跳跃", "射击":
			_search_audio(query)
		"image", "图片", "精灵", "背景", "角色":
			_search_images(query)
		_:
			# 默认搜索图片
			_search_images(query)

func _guess_category(query: String) -> String:
	var lower = query.to_lower()
	if "音" in lower or "sound" in lower or "爆炸" in lower or "跳" in lower or "射" in lower:
		return "audio"
	if "图" in lower or "精灵" in lower or "背景" in lower or "角色" in lower:
		return "image"
	return "image"

## 搜索图片素材
func _search_images(query: String) -> void:
	# Kenney 素材搜索 (通过关键词匹配)
	current_results = _search_kenney_images(query)

## 搜索音频素材
func _search_audio(query: String) -> void:
	# freesound API 需要 Key，这里用模拟数据
	current_results = _search_freesound_audio(query)

